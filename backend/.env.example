# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=REPLACE-WITH-A-REAL-RANDOM-SECRET

# ── Development only ─────────────────────────────────────────────────────────
# Set to True ONLY in local dev. Never True in production.
DEBUG=True
# Required when DEBUG=False; comma-separated list of allowed Host headers.
ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────────
EMAIL_HOST_USER=your@gmail.com
# Create at: myaccount.google.com → Security → App Passwords
EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Escape hatch for local dev (do NOT set in production) ────────────────────
# Uncomment to suppress the missing-SECRET_KEY error in local dev only.
DJANGO_ALLOW_INSECURE_KEY=1
